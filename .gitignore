# --- Binaries & Build Artifacts ---
bin/
tmp/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# --- Docker & Database ---
# データベースの実データは絶対にあげない
postgres_data/

# --- Environment Variables ---
# GitHubの秘密鍵などが入るため、絶対にあげない
.env
.env.*
!.env.example

# --- Go Dependencies ---
# go mod tidy で管理するため、基本は不要
vendor/
go.work
go.work.sum

# --- Code Coverage & Profiling ---
*.out
*.coverprofile
profile.cov
coverage.*

# --- Editor / IDE ---
# VSCodeの設定（チームで共有しない場合）
.vscode/
.idea/
*.swp
*.swo

# --- OS Specific ---
# Windows特有のキャッシュファイルなど
Thumbs.db
desktop.ini
.DS_Store